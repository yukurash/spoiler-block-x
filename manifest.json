{
  "manifest_version": 3,
  "name": "Spoiler Block for X",
  "version": "0.1.0",
  "description": "漫画のネタバレをXのタイムラインで自動ブロック",
  "permissions": ["storage"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
